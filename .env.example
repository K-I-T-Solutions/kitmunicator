# ── Datenbank ────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://kitmunicator:changeme@postgres:5432/kitmunicator

# ── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=kit
KEYCLOAK_CLIENT_ID=kitmunicator

# ── Asterisk ARI ──────────────────────────────────────────────────────────────
# ARI = Asterisk REST Interface
ASTERISK_ARI_URL=http://asterisk:8088
ASTERISK_ARI_USER=ari_user
ASTERISK_ARI_SECRET=changeme

# ── WorkmateOS CRM ───────────────────────────────────────────────────────────
WORKMATE_API_URL=https://api.workmate.example.com
WORKMATE_API_KEY=your-api-key-here

# ── n8n Workflow ─────────────────────────────────────────────────────────────
# Service-Account in Keycloak mit admin-cli Rolle (für User-Attribute setzen)
KEYCLOAK_ADMIN_CLIENT_ID=kitmunicator-service
KEYCLOAK_ADMIN_CLIENT_SECRET=changeme
# Webhook-Secret (Authorization-Header, den Keycloak mitschickt)
WEBHOOK_SECRET=changeme
# KITmunicator-URL (intern, für den n8n-Workflow)
KITMUNICATOR_API_URL=http://kitmunicator_backend:8000
# Erster SIP-Extension-Wert und Prefix (z.B. 1001, 1002, ...)
SIP_EXTENSION_START=1001
SIP_EXTENSION_PREFIX=

# ── Sipgate SIP-Trunk ────────────────────────────────────────────────────────
SIPGATE_USERNAME=your-sipgate-id
SIPGATE_PASSWORD=your-sipgate-password

# ── Asterisk ──────────────────────────────────────────────────────────────────
# Öffentliche IP des Asterisk-Hosts (für NAT/ICE)
ASTERISK_PUBLIC_IP=192.168.178.100

# ── coturn ────────────────────────────────────────────────────────────────────
TURN_EXTERNAL_IP=192.168.178.100
# Zufälliges Secret: openssl rand -hex 32
TURN_SECRET=changeme

# ── Prod-only ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
DOMAIN=kit-it-koblenz.de
REGISTRY=ghcr.io/kit-it-koblenz
TAG=latest

# ── Firebase / FCM ────────────────────────────────────────────────────────────
# Pfad zur Service-Account-JSON-Datei (wird als Volume ins Backend gemountet)
FIREBASE_SERVICE_ACCOUNT_FILE=/app/firebase-adminsdk.json
# Firebase-Projekt-ID (aus der firebase-adminsdk.json → "project_id")
FCM_PROJECT_ID=kitmunicator
# Shared Secret für den Asterisk→Backend Webhook (optional, leer = kein Check)
ASTERISK_WEBHOOK_SECRET=changeme

# ── App ───────────────────────────────────────────────────────────────────────
# Kommagetrennte Liste erlaubter Origins (für CORS)
CORS_ORIGINS=["http://localhost:5173","https://kit.example.com"]
DEBUG=false
